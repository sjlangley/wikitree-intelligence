# Google OAuth Configuration
# Get your client ID from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend API Base URL
# Development: Used for Vite dev server proxy (defaults to http://localhost:8000)
# Production: Used via import.meta.env.VITE_API_BASE_URL in api.ts for cross-origin requests
#             Leave empty for same-origin (relative path) requests
VITE_API_BASE_URL=http://localhost:8000
