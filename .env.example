# Google OAuth Configuration
# Get your client ID from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=not-a-real-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID=not-a-real-client-id.apps.googleusercontent.com

# Backend API Base URL
# For local development, this is typically http://localhost:8000
# Leave empty to use relative paths (same origin)
VITE_API_BASE_URL=http://localhost:8000


# Runtime environment (development, staging, production)
ENVIRONMENT=development

# Origins allowed to access the API (for CORS)
CLIENT_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Session secret key (use a strong, random value in production)
SESSION_SECRET_KEY=not-a-real-session-secret-key
